# Backend Database (Properties, Rooms) - SQL Server
GROQ_API_KEY=your_groq_api_key_here
DB_HOST=localhost
DB_PORT=1433
DB_NAME=staymatch_backend_db
DB_USER=sa
DB_PASSWORD=your_password_here

# Chatbot Database (Conversations, Messages) - PostgreSQL (Neon)
DATABASE_URL=postgresql+psycopg2://user:password@host:port/database_name
# .NET Property API Configuration
PROPERTY_API_BASE_URL=https://your-dotnet-api.com
PROPERTY_API_TOKEN=your-dotnet-api-token

# JWT Authentication Configuration
JWT_SECRET=your-jwt-secret-key
JWT_ISSUER=your-jwt-issuer
GEMINI_API_KEY=your-gemini-api-key
JWT_AUDIENCE=your-jwt-audience